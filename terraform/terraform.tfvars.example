# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — it will NOT be committed.

# Required — get these from Science IT / Cloud Console
project_id         = "your-gcp-project-id"
billing_account_id = "XXXXXX-XXXXXX-XXXXXX"

# Required — build and push the container first:
#   cd budget-enforcer/
#   gcloud builds submit --tag gcr.io/YOUR_PROJECT_ID/budget-enforcer .
container_image = "gcr.io/your-gcp-project-id/budget-enforcer"

# Optional — override defaults
# resource_prefix       = "tf"       # Prefix for all GCP resource names
# consumer_sa_name      = "vertex-ai-consumer"
# admin_sa_name         = "budget-enforcer-admin"
# vertex_ai_region      = "us-east5"
# cloud_run_region      = "us-central1"
# monthly_budget_amount = 100
# budget_display_name   = ""         # Defaults to "{prefix}-vertex-ai-monthly-budget"

# Flux estimator — real-time spend estimation (bridges 12-24h billing lag)
# flux_mode               = "call_count"  # "call_count" for Anthropic, "token" for Google models
# flux_window_hours       = 48            # Hours of call data to estimate from
# cost_per_call_expensive = "0.30"        # USD per Opus-class call (upper bound)
# cost_per_call_cheap     = "0.01"        # USD per Haiku-class call (upper bound)
# enforcement_tolerance   = "1.0"         # 0.8=early cutoff, 1.0=exact, 1.2=tolerant
